# ── TradeMindset Web — Variables d'environnement ─────────────────────────────
# Copie ce fichier en .env.local et remplis les valeurs
# Firebase Console → Project settings → Your apps → Web app

VITE_FIREBASE_API_KEY=AIzaSy...
VITE_FIREBASE_AUTH_DOMAIN=ton-projet.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=ton-projet
VITE_FIREBASE_STORAGE_BUCKET=ton-projet.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123

# Sur Vercel : ajoute ces variables dans Settings → Environment Variables
# Elles sont automatiquement disponibles en production
